archie.biotron.it {
    encode gzip zstd

    handle /api/* {
        reverse_proxy backend_nginx:80
    }

    handle /admin/* {
        reverse_proxy backend_nginx:80
    }

    handle /static/* {
        reverse_proxy backend_nginx:80
    }

    handle /media/* {
        reverse_proxy backend_nginx:80
    }

    handle {
        reverse_proxy frontend:80
    }
}
