# ─── Template — copiare in .env (dev) o .env.prod (prod) ─────────────────────
#
# Ambienti:
#   Dev:  cp .env.example .env          → docker compose up
#   Prod: cp .env.example .env.prod     → compilare tutti i CHANGE-ME
#         docker compose -f docker-compose.yml -f docker-compose.prod.yml up
#
# .env e .env.prod sono in .gitignore — non vengono committati.
# ──────────────────────────────────────────────────────────────────────────────

# Genera con: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me

# 1 = dev, 0 = prod
DJANGO_DEBUG=1

# Dev: * va bene. Prod: IP/dominio esatti separati da virgola.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=inventory_app
DB_USER=inventory_app
# OBBLIGATORIA: nessun default sicuro. In prod usare una password forte.
DB_PASSWORD=inventory_app
DB_HOST=db
DB_PORT=5432

# Necessario solo in prod per il servizio db (docker-compose.prod.yml)
POSTGRES_DB=inventory_app
POSTGRES_USER=inventory_app
POSTGRES_PASSWORD=inventory_app

# ── Sicurezza ─────────────────────────────────────────────────────────────────

# Chiave di cifratura at-rest per campi sensibili (os_pwd, app_pwd, vnc_pwd).
# Dev: può essere vuota (derivata da SECRET_KEY).
# Prod (DEBUG=0): OBBLIGATORIA. Fare backup — senza di essa i dati cifrati sono irrecuperabili.
# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
TIME_ZONE=Europe/Rome
APP_VERSION=0.5.0

MAINTENANCE_ALERT_EMAIL=maintenance@example.local

# ── CSRF ──────────────────────────────────────────────────────────────────────
# ATTENZIONE: CSRF_ALLOW_ALL_ORIGINS=1 fa fallire l'avvio se DJANGO_DEBUG=0.
# In prod: lasciare 0 e compilare CSRF_TRUSTED_ORIGINS.
CSRF_ALLOW_ALL_ORIGINS=0

# Origini fidate (host+porta). Esempio: http://192.168.1.10:6382,http://192.168.1.10:6383
CSRF_TRUSTED_ORIGINS=


# ── Login hardening ─────────────────────────────────────────────────────────
# Numero massimo di tentativi falliti per username nella finestra temporale.
AUTH_LOGIN_FAILURE_LIMIT=5
# Limite più ampio per IP, utile contro spray attack e brute force distribuiti per utente.
AUTH_LOGIN_IP_FAILURE_LIMIT=20
# Finestra del rate limit in secondi (default: 15 minuti).
AUTH_LOGIN_WINDOW_SECONDS=900

# ── Cache / Redis ─────────────────────────────────────────────────────────────
# Usata per il rate-limiting sul login (condiviso tra worker Gunicorn).
# Dev: lasciare vuota per usare LocMemCache (un processo solo).
# Prod: OBBLIGATORIA con più worker Gunicorn. Esempio: redis://redis:6379/1
# Formato: redis://[user:password@]host[:port][/db]
REDIS_URL=redis://redis:6379/1

# ── Gunicorn (prod, opzionali) ────────────────────────────────────────────────
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=120

# ── Proxy / HTTPS hardening (prod) ───────────────────────────────────────────
# Se il traffico HTTPS termina su nginx/reverse proxy, lascia 1 per rispettare
# X-Forwarded-Proto/X-Forwarded-Host. In dev puoi lasciarli ai default.
DJANGO_USE_X_FORWARDED_HOST=1
DJANGO_SECURE_PROXY_SSL_HEADER=1

# Cookie/session hardening. In prod tipicamente 1.
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SESSION_COOKIE_HTTPONLY=1
DJANGO_CSRF_COOKIE_HTTPONLY=0
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax

# Reindirizza HTTP -> HTTPS solo quando il proxy esterno serve davvero HTTPS.
DJANGO_SECURE_SSL_REDIRECT=0

# HSTS: attivalo solo quando tutto il traffico pubblico e' HTTPS.
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0

# Esegue `manage.py check --deploy` all'avvio del backend.
DJANGO_RUN_DEPLOY_CHECK=0
